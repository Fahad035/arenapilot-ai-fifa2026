# ==========================
# ArenaPilot AI Backend
# ==========================

# Server
PORT=5000
NODE_ENV=development

# Google Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# CORS
FRONTEND_URL=http://localhost:5173

# AI Configuration
AI_MODEL=gemini-2.5-flash
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048

# Logging
LOG_LEVEL=info

# Enable Mock Responses
USE_MOCK_AI=true
